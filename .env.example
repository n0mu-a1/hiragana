# Turso (libSQL) 接続。`turso db show <name> --url` と `turso db tokens create <name>` で取得。
TURSO_DATABASE_URL=libsql://hiragana-xxxx.turso.io
TURSO_AUTH_TOKEN=

# 設定すると /api/feedback の Origin を限定。空なら検証用に誰でもPOST可。
FEEDBACK_ALLOW_ORIGIN=https://hiragana.example.com

# コメント分類。既定は無料 heuristic。GROQ_API_KEY があれば無料LLM→heuristic。
GROQ_API_KEY=
ANTHROPIC_API_KEY=
REFLEX_NLP_PROVIDER=

# schema 適用用
TURSO_DB_NAME=hiragana
